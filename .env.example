# =============================================================
# PLANTILLA DE CONFIGURACIÓN
# =============================================================
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env" (sin el .example)
# 2. Reemplaza cada valor entre <> con tus datos reales
# 3. NUNCA subas el archivo .env a Git o lo compartas
# =============================================================

# --- Opera Cloud (Oracle Hospitality) ---
OPERA_URL=https://mtcu11.oraclehospitality.us-ashburn-1.ocs.oraclecloud.com/ECRWLG/operacloud
OPERA_USUARIO=<usuario_de_la_cuenta_servicio>
OPERA_PASSWORD=<password_de_la_cuenta_servicio>
OPERA_PROPIEDAD=COWLCR

# --- Integrity ERP (se usa en Fase 2, ya podés dejarlo configurado) ---
INTEGRITY_URL=https://www.programarcr.com/conta506/index.aspx
INTEGRITY_USUARIO=<usuario_de_la_cuenta_servicio>
INTEGRITY_PASSWORD=<password_de_la_cuenta_servicio>

# --- Rutas locales ---
CARPETA_DESCARGAS=C:\Proyectos\automatizacion-reporte\descargas
CARPETA_LOGS=C:\Proyectos\automatizacion-reporte\logs
CARPETA_CAPTURAS=C:\Proyectos\automatizacion-reporte\capturas

# --- Configuración del navegador ---
# Modo headless:
#   False = visible (úsalo en desarrollo, ves al bot trabajando)
#   True  = invisible (úsalo en producción, más rápido)
MODO_HEADLESS=False

# Timeout en segundos (cuánto espera por una acción del navegador)
TIMEOUT_SEGUNDOS=180

# --- Logging ---
# Niveles: DEBUG (todo), INFO (normal), WARNING, ERROR
NIVEL_LOG=INFO

# --- Notificaciones por email ---
# Si usás Gmail: smtp.gmail.com puerto 587, y necesitás un "App Password"
# (no tu password normal). Generalo en: https://myaccount.google.com/apppasswords
# Para otros proveedores, consultá su documentación de SMTP.
EMAIL_SMTP_SERVIDOR=smtp.gmail.com
EMAIL_SMTP_PUERTO=587
EMAIL_REMITENTE=<tu_email@gmail.com>
EMAIL_PASSWORD=<app_password_de_16_caracteres>

# Destinatarios separados por coma (sin espacios después de la coma)
EMAIL_DESTINATARIOS=<tu_email@empresa.com>,<otro@empresa.com>
